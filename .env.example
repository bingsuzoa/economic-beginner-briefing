NODE_ENV=development
TZ=Asia/Seoul
DRY_RUN=true
LOG_LEVEL=info

# OpenAI (feature/ai-analysis에서 사용)
OPENAI_API_KEY=

# Notion (feature/notion-publisher에서 사용)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Email (feature/email-publisher에서 사용)
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_TO=
EMAIL_API_KEY=

# Database (Admin Dashboard 사용 시 필요)
# DATABASE_URL 설정 시 개별 DB_* 변수보다 우선 사용
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=economic_briefing
DB_USER=postgres
DB_PASSWORD=

# Admin Dashboard
ADMIN_TOKEN=your-secret-admin-token
ADMIN_PORT=3000
